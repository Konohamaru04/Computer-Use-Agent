{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComputerUse",
  "version": "0.1.0",
  "identifier": "local.computeruse.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ComputerUse",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      },
      {
        "label": "widget",
        "title": "ComputerUse Status",
        "url": "overlay.html",
        "width": 400,
        "height": 188,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "focus": false,
        "focusable": false,
        "shadow": false
      },
      {
        "label": "cursor-widget",
        "title": "ComputerUse Cursor",
        "url": "cursor.html",
        "width": 178,
        "height": 58,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "focus": false,
        "focusable": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "cursor-marker",
        "title": "ComputerUse Cursor Marker",
        "url": "cursorMarker.html",
        "width": 48,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "focus": false,
        "focusable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420",
      "assetProtocol": {
        "enable": true,
        "scope": ["E:/ComputerUse/screenshots/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
